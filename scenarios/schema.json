{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scenario.schema.json",
  "title": "Scenario",
  "description": "A single StoryTelling scenario definition.",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier — must match the filename (without .json).",
      "pattern": "^[a-z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "icon": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scenarioPrompt": {
      "type": ["string", "null"],
      "description": "Scenario-specific narrator instructions injected into every prompt."
    },
    "openingText": {
      "type": ["string", "null"],
      "description": "First narrative paragraph shown to the player. Seeded as the first assistant message."
    },
    "mainCharacters": {
      "type": "array",
      "description": "Pre-filled character suggestions shown on the setup screen.",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name":        { "type": "string", "minLength": 1 },
          "class":       { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "cards": {
      "type": "array",
      "description": "World-context cards injected into the prompt when trigger keywords match.",
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["location", "npc", "item", "faction", "lore"]
          },
          "name":        { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "triggers": {
            "type": "string",
            "description": "Comma-separated keywords. Empty = always injected (pinned)."
          }
        }
      }
    }
  }
}
